{
    "include": ["**/*.ts"],
    "exclude": ["**/node_modules"],
    "compilerOptions": {
        "module": "ESNext",
        "target": "ES2024",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "paths": {
            "@/*": ["./src/*"],
            "@lib/*": ["./lib/*"],
        },
    },
}
